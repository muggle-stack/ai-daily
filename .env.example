# ===== 必填 =====
# Anthropic API Key（与 ANTHROPIC_AUTH_TOKEN 二选一）
# ANTHROPIC_API_KEY=sk-ant-xxxxx
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 飞书云空间文件夹 token（日报文件上传到此文件夹）
FEISHU_FOLDER_TOKEN=
FEISHU_DOC_OWNER_ID=

# ===== 选填 =====
# 第三方兼容端点的 Bearer Token（与 ANTHROPIC_API_KEY 二选一）
ANTHROPIC_AUTH_TOKEN=
# 自定义 API 端点（用于第三方兼容 Anthropic 协议的服务）
ANTHROPIC_BASE_URL=
# 飞书 API 基础 URL（默认 https://open.feishu.cn）
# FEISHU_BASE_URL=https://open.feishu.cn
# 飞书文档链接前缀（默认 https://feishu.cn）
# FEISHU_DOC_URL_PREFIX=https://feishu.cn
# 飞书群 chat_id（不填则不发送群通知）
# FEISHU_CHAT_ID=oc_xxxxx
# Claude 模型（默认 claude-sonnet-4-20250514）
CLAUDE_MODEL=claude-opus-4-6
# 最终保留的文章数量（默认 15）
TOP_N=15
# 自定义 RSS 源（逗号分隔，不填使用默认源）
RSS_FEEDS=
# 日志级别（默认 INFO）
LOG_LEVEL=INFO
